# Writing LMS 환경 변수 예시

# 실행 환경: development / local / production
ENV=development

# 앱 메타 / 로깅 (공백 포함 값은 셸 소싱 대비 따옴표로 감쌀 것)
APP_NAME="Writing LMS"
LOG_LEVEL=INFO

# DB (SQLAlchemy 비동기 DSN, psycopg 드라이버)
# 예) postgresql+psycopg://postgres:postgres@localhost:5432/writing_lms
DATABASE_URL=
DB_ECHO=false

# 인증 (로컬 JWT HS256) — 강력한 랜덤 값 생성: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 어드민(교사) 부트스트랩 계정 — `make seed-admin`이 이 값으로 계정을 upsert(멱등)
# 비밀번호는 평문이 아니라 bcrypt 해시로 저장: `make hash-password`로 생성.
# ADMIN_PASSWORD_HASH는 반드시 '작은따옴표'로 감쌀 것(bcrypt의 $ 가 셸에서 확장되지 않도록).
# 미설정 시 시드는 건너뜀.
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=''
ADMIN_NAME=

# LLM (init_chat_model "provider:model" 규격)
# 예) openai:gpt-4o-mini / anthropic:claude-... / ollama:exaone3.5:7.8b
LLM_MODEL=ollama:exaone3.5:7.8b
LLM_TEMPERATURE=0.3
# 클라우드 프로바이더 사용 시 해당 키
OPENAI_API_KEY=

# Ollama (로컬 LLM) — LLM_MODEL이 ollama:* 일 때 base_url로 사용
OLLAMA_HOST=http://localhost:11434

# OCR 백엔드 (stub | tesseract | easyocr | paddleocr | vision_llm)
OCR_BACKEND=stub

# CORS 허용 오리진 (콤마 구분)
CORS_ORIGINS=*
