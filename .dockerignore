# 빌드 컨텍스트 최소화 — 이미지에 불필요한 파일 제외
.git
.gitignore
.venv
__pycache__
**/__pycache__
*.pyc
.mypy_cache
.mypy_cache_test
.ruff_cache
.pytest_cache

# 로컬 환경/시크릿 (컨테이너엔 env_file/environment로 주입)
.env
.env.*
!.env.example

# 개발/IDE
.idea
.vscode
.DS_Store
.claude

# 도커 자체
Dockerfile
.dockerignore
docker-compose.yml

# 런타임에 불필요한 자료/산출물
data
tests
CHANGELOG.md
